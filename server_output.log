      'GLOBAL TEMPORARY' AS TYPE
    FROM
      sqlite_temp_master
    UNION ALL
    SELECT
      NAME,
      'SYSTEM TABLE' AS TYPE
    FROM
      sqlite_schema
    WHERE
      NAME LIKE 'sqlite\_%' ESCAPE '\'
  )
 WHERE TABLE_NAME LIKE '%' ESCAPE '\' AND TABLE_TYPE IN ('TABLE') ORDER BY TABLE_TYPE, TABLE_NAME;
