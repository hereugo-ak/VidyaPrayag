<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!-- Deep links: vidyaprayag://app/<path> — used by notification taps
	     and future external linking. Matches AndroidManifest scheme. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.littlebridge.enrollplus.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>vidyaprayag</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
