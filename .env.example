# ===================================================================
# VidyaPrayag Backend — Environment Variables
# Copy this file to `.env` and fill in real values for your environment.
# DO NOT commit `.env` — only `.env.example` is tracked.
# ===================================================================

# -------------------------------------------------------------------
# DATABASE
# -------------------------------------------------------------------
# Supabase Postgres connection string (production / staging).
# Get this from Supabase Dashboard → Project Settings → Database →
# "Connection string" → URI tab. Use the *Transaction Pooler* (port
# 6543) string for serverless or short-lived workloads, or the
# *Session Pooler* (port 5432) string for long-lived JDBC connections
# like this Ktor server.
#
# Accepted forms (the backend normalises all of them):
#   postgres://postgres:[PWD]@db.[REF].supabase.co:5432/postgres
#   postgresql://postgres:[PWD]@db.[REF].supabase.co:5432/postgres
#   jdbc:postgresql://db.[REF].supabase.co:5432/postgres?user=postgres&password=[PWD]
#
# DO NOT wrap the value in quotes. Write it bare:
#   DATABASE_URL=jdbc:postgresql://host:5432/postgres?sslmode=require
# NOT:
#   DATABASE_URL="jdbc:postgresql://host:5432/postgres?sslmode=require"
# (A quoted value in a .properties / .env file is read literally WITH the quotes
#  and produced the doubled URL jdbc:postgresql://"jdbc:postgresql://...". The
#  backend now strips surrounding quotes defensively, but keep it clean anyway.)
#
# If DATABASE_URL is empty or missing, the server falls back to a
# local SQLite file (./vidyaprayag.db) — useful for offline dev but
# UUID columns get stored as BLOB.
DATABASE_URL=

# Optional: only needed when the user/password are NOT already encoded in
# DATABASE_URL. With Supabase Session Pooler the username is usually
# "postgres.<project-ref>". The server reads these from .env, the OS
# environment, OR local.properties (git-ignored) — in that order.
DATABASE_USER=
DATABASE_PASSWORD=

# Set to "true" ONLY if you want the ORM to create missing tables on a fresh
# Postgres. Against a Supabase DB provisioned by docs/db/PROVISION.sql leave
# this UNSET — the server validates the schema at boot and refuses to start
# if tables are missing (so a bad provisioning recipe fails loud, not silent).
AUTO_CREATE_TABLES=

# -------------------------------------------------------------------
# CORS — allowed browser origins (RA-37)
# -------------------------------------------------------------------
# In production (DATABASE_URL set) CORS is locked to this comma-separated
# allow-list. Each entry may be a bare host (app.example.com), a host:port,
# or include a scheme (https://app.example.com). If left empty in prod, CORS
# falls back to anyHost() — set this before launch. Ignored in local dev.
CORS_ALLOWED_ORIGINS=

# -------------------------------------------------------------------
# SUPABASE STORAGE — REAL binary media uploads (logo, gallery, videos)
# -------------------------------------------------------------------
# These power POST /api/v1/school/media/upload, which turns the school-side
# media flows from "paste a URL" placeholders into genuine file uploads.
#
# If SUPABASE_URL or SUPABASE_SERVICE_KEY are MISSING, the server still
# boots fine — the upload endpoint just returns 503 STORAGE_NOT_CONFIGURED
# until you set them. So it's safe to deploy before wiring storage.
#
# SUPABASE_URL: your project base URL.
#   Supabase Dashboard → Project Settings → API → "Project URL"
#   e.g. https://abcdwxyz.supabase.co   (NO trailing slash needed)
SUPABASE_URL=
#
# SUPABASE_SERVICE_KEY: the SERVICE ROLE secret (NOT the anon key!).
#   Supabase Dashboard → Project Settings → API → "service_role" secret.
#   This bypasses RLS so the server can write on behalf of any school.
#   Treat it like a password — never expose it to the client app.
SUPABASE_SERVICE_KEY=
#
# SUPABASE_BUCKET: storage bucket name (default "school-media").
#   Create it in Supabase Dashboard → Storage → New bucket →
#   name it "school-media" and mark it PUBLIC so the returned URLs load
#   without signed tokens.
SUPABASE_BUCKET=school-media

# -------------------------------------------------------------------
# SERVER
# -------------------------------------------------------------------
# HTTP port the Ktor server listens on. Default is 8080.
PORT=8080

# -------------------------------------------------------------------
# JWT
# -------------------------------------------------------------------
# Long random string used to sign access tokens. MUST be set in
# production. In dev a hardcoded fallback is used (insecure).
# Generate a strong one with:
#   openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-string

# Access token lifetime in minutes (default 60).
JWT_ACCESS_MINUTES=60

# Refresh token lifetime in days (default 30).
JWT_REFRESH_DAYS=30

# -------------------------------------------------------------------
# OTP — Industrial-Grade One-Time Password Service
# -------------------------------------------------------------------
# Global pepper added to every OTP hash. Combined with a per-row salt
# this means a database-only dump cannot be used to brute-force OTPs.
# Generate with:
#   openssl rand -hex 32
# IMPORTANT: rotating this invalidates all in-flight OTPs.
OTP_PEPPER=change-me-to-a-long-random-string

# OTP lifetime in minutes (default 10).
OTP_EXPIRY_MINUTES=10

# Max wrong attempts per OTP before the row is locked (default 5).
OTP_MAX_ATTEMPTS=5

# Max OTP sends per identifier in a rolling 1-hour window (default 5).
OTP_MAX_RESENDS_PER_HOUR=5

# When true, the /send-otp response includes a `dev_code` field with
# the plain OTP for Postman/curl testing without SMS infrastructure.
# RA-33: the default is now `false` (opt-in only) and the echo is HARD-GATED
# to non-production — even if set to `true`, it is force-suppressed whenever
# DATABASE_URL is configured. Leave unset in production.
OTP_DEV_RETURN_CODE=false

# -------------------------------------------------------------------
# OTP DELIVERY — Multi-Provider Chain
# -------------------------------------------------------------------
# The backend ships a chain-of-responsibility dispatcher that tries
# providers in order until one succeeds.  Set the chain order with:
#
#   OTP_CHANNEL_ORDER   CSV of channels in preference order
#                       Valid values: sms,whatsapp,email,voice
#                       Default: "sms,whatsapp,email"
#
#   OTP_PROVIDER_ORDER  (advanced) CSV of provider NAMES, hard-pinned.
#                       Overrides OTP_CHANNEL_ORDER when set.
#                       Example:
#                         whatsapp_cloud,fast2sms,msg91,twilio,smtp,console
#
#   OTP_PROVIDER        (legacy) Hard-pin to ONE provider.  When set
#                       to a known name (e.g. "fast2sms"), skips the
#                       chain entirely.  Useful during incident response.
#                       Use "auto" or leave blank for default chain.
#
OTP_CHANNEL_ORDER=sms,whatsapp,email
OTP_PROVIDER_ORDER=
OTP_PROVIDER=

# Console fallback — prints OTP to stdout when no real provider is
# configured.  ONLY for local dev / CI; MUST be false in production.
# On Render free tier with NO provider creds set: leave this `true` so
# the app stays green during the first deploy + smoke test.  Flip to
# `false` and pair with OTP_DEV_RETURN_CODE=false once a real provider
# (Fast2SMS / MSG91 / WhatsApp Cloud) is wired up.
OTP_ENABLE_CONSOLE_FALLBACK=true

# Ops-only admin endpoints (diagnostic / audit / test-send).
# When this is BLANK the entire /api/v1/admin/otp/* route group is
# unmounted (404).  Set in production to a 32+ char random string:
#   openssl rand -hex 32
OTP_ADMIN_TOKEN=

# -------------------------------------------------------------------
# Provider creds — set ONLY the ones you actually have.  Unset providers
# are automatically skipped by the dispatcher (no network round-trip).
# -------------------------------------------------------------------

# --- Fast2SMS (India SMS, primary cheap option — ~₹0.15-0.25 per OTP) ---
# Get key:  https://www.fast2sms.com → Dev API → API Key
# FAST2SMS_ROUTE=otp uses the OTP route (no DLT template needed).
# FAST2SMS_ROUTE=dlt requires SENDER_ID + DLT_TEMPLATE_ID approved on DLT.
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=otp
FAST2SMS_SENDER_ID=
FAST2SMS_DLT_TEMPLATE_ID=

# --- MSG91 (India SMS, DLT-compliant flow API) ---
# Get key:  https://control.msg91.com → API → Auth Keys
# Get flow id: dashboard → Flow → your OTP template
MSG91_AUTH_KEY=
MSG91_FLOW_ID=
MSG91_OTP_VAR_NAME=OTP
MSG91_SENDER_ID=

# --- Twilio (international SMS + WhatsApp fallback) ---
# Get credentials: https://console.twilio.com
# TWILIO_FROM = "+15551234567"   for SMS
# TWILIO_FROM = "whatsapp:+14155238886"   for WhatsApp sandbox
# TWILIO_CHANNEL = "sms" | "whatsapp"
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_CHANNEL=sms

# --- WhatsApp Cloud API (Meta, FREE up to 1000 conversations/month) ---
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# 1) Create app → add "WhatsApp" product
# 2) Get a long-lived system-user access token (60-day or permanent)
# 3) Note PHONE_NUMBER_ID from the WhatsApp panel
# 4) Submit an "authentication" template named e.g. "vidyaprayag_otp"
#    with body "{{1}} is your verification code" and ONE url-button.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=vidyaprayag_otp
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_API_VERSION=v19.0
WHATSAPP_INCLUDE_BUTTON=true

# --- SMTP (email OTP — FREE forever via Gmail/Resend/SES/Brevo/Postmark) ---
# Choose port + TLS mode based on provider:
#   Gmail:    smtp.gmail.com   :465 SSL=true   (use an App Password)
#   Resend:   smtp.resend.com  :465 SSL=true   (API key as password)
#   SES:      email-smtp.{region}.amazonaws.com :587 STARTTLS=true
#   Brevo:    smtp-relay.brevo.com :587 STARTTLS=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=VidyaPrayag <noreply@example.com>
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_MS=8000

# -------------------------------------------------------------------
# SEEDING
# -------------------------------------------------------------------
# When true, the server seeds CMS strings (cms_landing_content +
# app_config) on boot. Safe to leave on — it only inserts missing
# keys, never overwrites existing values. Set false to disable.
APP_SEED_CMS=true

# When true, the server seeds ONE working credential per profile type plus
# minimal operational demo data (school, child, fees, announcement) so a fresh
# deploy is immediately loginable. Idempotent. Set false on a real production
# tenant that must not contain demo accounts.
#   super@vidyaprayag.demo / Demo@1234   (super_admin)
#   admin@vidyaprayag.demo / Demo@1234   (school_admin)
#   teacher@vidyaprayag.demo / Demo@1234 (teacher)
#   parent@vidyaprayag.demo / Demo@1234  (parent + linked child)
APP_SEED_DEMO=true

# -------------------------------------------------------------------
# OBSERVABILITY & DEBUGGING (RA-40)
# -------------------------------------------------------------------
# DEBUG_ERRORS controls whether a 500 response echoes the raw exception
# message to the client.
#   - Default (unset / anything but "true"): clients get a generic
#     "Something went wrong. Please try again later." — never leaks internals.
#   - "true": the raw exception message is returned (DEV ONLY — useful when
#     debugging a local crash).
# HARD GATE: even if DEBUG_ERRORS=true is set, the leak is SUPPRESSED whenever
# DATABASE_URL is configured (the production signal). NEVER set this true in prod.
# Unhandled errors are always logged via SLF4J (see server/.../logback.xml) so a
# Sentry SLF4J appender / log shipper can pick them up.
DEBUG_ERRORS=false

# -------------------------------------------------------------------
# LOGIN THROTTLE (RA-41)
# -------------------------------------------------------------------
# Sliding-window throttle on the email/password login path (the phone/OTP path
# is throttled separately by OtpService). A request is blocked when EITHER the
# per-IP window OR the per-identifier window exceeds LOGIN_MAX_ATTEMPTS failures
# within LOGIN_WINDOW_SECONDS; a successful login clears the identifier window.
#   LOGIN_MAX_ATTEMPTS    max failed attempts per window  (default 8, range 3-100)
#   LOGIN_WINDOW_SECONDS  window length in seconds        (default 900 = 15m, range 30-86400)
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=900

# -------------------------------------------------------------------
# FIREBASE — PRIMARY APP (Enroll / VidyaPrayag push notifications)
# -------------------------------------------------------------------
# The server-side Firebase Admin SDK pushes user-facing notifications via this
# project. Resolution order (first non-blank wins), see FirebaseAdminInitializer:
#   1. FIREBASE_CREDENTIALS_JSON      full service-account JSON (inline)
#   2. FIREBASE_CREDENTIALS_FILE      absolute path to the service-account JSON
#   3. GOOGLE_APPLICATION_CREDENTIALS Google ADC convention (path)
#   4. local.properties (firebase.credentials.file)  — laptop DX only
# When NONE resolve, push dispatch degrades to a no-op (never crashes boot).
# FIREBASE_CREDENTIALS_JSON=
# FIREBASE_CREDENTIALS_FILE=/etc/secrets/enrollplus-firebase-adminsdk.json
# Example (local.properties): firebase.credentials.file=/Users/you/Secrets/enrollplus-firebase-adminsdk.json

# -------------------------------------------------------------------
# OTPSENDER SMS GATEWAY (feature/setup_notification)
# -------------------------------------------------------------------
# The OTPSender Android app is an SMS gateway: the backend pushes an FCM
# data-message to a registered OTPSender phone, and that phone sends the OTP
# SMS from its own SIM. No SMS vendor is billed on this path.
#
# 1) FIREBASE — OTPSENDER APP (a SEPARATE Firebase project from the primary app)
#    Each app needs its OWN service-account credential. Mirror the FIREBASE_*
#    family with an OTP_SENDER_ prefix. NO ADC fallback here (ADC is process-
#    global and would resolve to the PRIMARY project, sending to the wrong app).
# OTP_SENDER_FIREBASE_CREDENTIALS_JSON=
# OTP_SENDER_FIREBASE_CREDENTIALS_FILE=/etc/secrets/otpsender-firebase-adminsdk.json
# Example (local.properties): otp.sender.firebase.credentials.file=/Users/you/Secrets/otpsender-firebase-adminsdk.json
#
# 2) GATEWAY ROUTING — shared secret for the OTPSender device <-> backend API.
#    When OTP_GATEWAY_TOKEN is UNSET the entire /api/v1/gateway/* surface is
#    404'd (its existence is not advertised). When set, every gateway request
#    must present a matching X-Gateway-Token header.
# OTP_GATEWAY_TOKEN=change-me-to-a-long-random-secret
#
# 3) OTP DELIVERY SWITCH — route phone OTPs through the gateway instead of the
#    direct SMS-provider chain. When false (default) OTPs use the existing
#    Fast2SMS/MSG91/Twilio/SMTP/Console chain unchanged. Email OTPs always use
#    the direct chain (the gateway only sends SMS).
# OTP_GATEWAY_ENABLED=false
#
# 4) DEVICE LIVENESS WINDOW (minutes) — a gateway device is eligible for
#    dispatch only when is_active=true AND last_seen_at is within this window.
#    Default 5 (per spec). Range 1-60.
# OTP_GATEWAY_LIVENESS_MINUTES=5

# ===================================================================
# AI GATEWAY — provider-agnostic LLM access (PEWS + future AI features)
# ===================================================================
# The backend routes every LLM call through ONE gateway (AiService) over
# 5 OpenAI-compatible FREE-TIER providers. Set ONLY the keys you have;
# unset providers are automatically skipped (the breaker never tries
# them). With ZERO keys set, AI features degrade gracefully — PEWS still
# produces its deterministic risk signals; only the AI *explanation*
# text is omitted. The app stays green.
#
# Key management is two-layer (see KeyVault.kt):
#   1. On boot, each AI_<PROVIDER>_API_KEY below is read, encrypted with
#      AI_ENCRYPTION_KEY (AES-256-GCM), and upserted into
#      ai_provider_config.api_key_encrypted.
#   2. At call time KeyVault decrypts on demand with an in-memory cache,
#      so keys can be ROTATED via the admin endpoint WITHOUT a redeploy.
# Env read = System.getenv → root local.properties fallback.
# -------------------------------------------------------------------

# --- Encryption key for provider secrets at rest (REQUIRED in prod) ---
# 64-char hex (32 bytes) OR a long passphrase (SHA-256 → 32 bytes).
# Generate:  openssl rand -hex 32
# If UNSET, provider keys are stored in DEV passthrough mode (NOT
# encrypted) and a warning is logged. MUST be set in production.
AI_ENCRYPTION_KEY=

# --- Provider API keys — set ONLY the ones you actually have ---------
# Privacy routing: PII prompts are sent ONLY to no-training providers
# (Cerebras / Groq / OpenRouter). Mistral / SambaNova are used for
# non-PII batch/reasoning work only.

# Cerebras (FAST lane, no-training). Get key: https://cloud.cerebras.ai
AI_CEREBRAS_API_KEY=
# Optional overrides (defaults shown in comments):
# AI_CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# AI_MODEL_CEREBRAS=gpt-oss-120b

# Groq (REASON/CLASSIFY lane, no-training). Get key: https://console.groq.com
AI_GROQ_API_KEY=
# AI_GROQ_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL_GROQ_REASON=llama-3.3-70b-versatile

# SambaNova (REASON lane; training opt-in → NON-PII only). https://cloud.sambanova.ai
AI_SAMBANOVA_API_KEY=
# AI_SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
# AI_MODEL_SAMBANOVA=DeepSeek-V3.1

# Mistral (BATCH lane; training opt-in → NON-PII only). https://console.mistral.ai
AI_MISTRAL_API_KEY=
# AI_MISTRAL_BASE_URL=https://api.mistral.ai/v1
# AI_MODEL_MISTRAL=mistral-large-latest

# OpenRouter (REASON fallback, no-training). https://openrouter.ai/keys
AI_OPENROUTER_API_KEY=
# AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL_OPENROUTER=meta-llama/llama-3.3-70b-instruct:free

# NVIDIA NIM (REASON + FAST lanes, no-training). Get key: https://build.nvidia.com
# NVIDIA_REASON and NVIDIA_FAST share the same API key.
AI_NVIDIA_REASON_API_KEY=
# AI_NVIDIA_REASON_BASE_URL=https://integrate.api.nvidia.com/v1
# AI_MODEL_NVIDIA_REASON=meta/llama-3.3-70b-instruct
# AI_MODEL_NVIDIA_FAST=meta/llama-3.1-8b-instruct

# --- Circuit breaker tuning (optional) ------------------------------
# Consecutive failures before a (provider, model) is tripped OPEN.
# AI_CIRCUIT_FAILS_TO_OPEN=5
# Seconds to stay OPEN before a single HALF_OPEN probe is allowed.
# AI_CIRCUIT_COOLDOWN_SEC=30

# ===================================================================
# PEWS — Predictive Early Warning System (first AI feature)
# ===================================================================
# Daily job: Sense (deterministic SQL) → Reason (LLM explains only) →
# Act (intervention + notify) → Learn (outcome tracking). Per-school
# thresholds & toggles live in the pews_config table (set in-app).

# Master switch. Set to "false" to disable the daily job entirely.
# Any other value (or unset) leaves PEWS ENABLED.
# PEWS_ENABLED=true

# Hour (UTC, 0-23) at which the daily recompute runs. Default 0 (midnight UTC).
# PEWS_RUN_HOUR_UTC=0

# Day of week for schools with run_frequency=weekly. Default MONDAY.
# Values: MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY, SUNDAY
# PEWS_RUN_DAY_OF_WEEK=MONDAY
