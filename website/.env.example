# ===================================================================
# Enroll+ Website — Environment
# Copy to `.env.local` for local dev. Only ONE variable is required.
# ===================================================================

# Base URL of the existing Ktor backend the website talks to.
# - Local dev (Ktor on your machine):   http://localhost:8080
# - Staging/Prod (deployed backend):    https://your-backend.onrender.com
#
# This is the SAME backend the mobile app uses. The website only calls
# the public auth + JWT-authed onboarding routes — it never touches the DB
# directly.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
