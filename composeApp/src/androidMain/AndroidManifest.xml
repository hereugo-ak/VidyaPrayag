<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Real "use current location" in school onboarding (report §11.2). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Required on API 33+ (Tiramisu) to post foreground/local notifications.
         Requested at runtime; NotificationManagerHelper gates posting on
         NotificationManagerCompat.areNotificationsEnabled() as well. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".EnRollPlusApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.VidyaPrayag">
        <activity
            android:exported="true"
            android:name=".MainActivity"
            android:theme="@style/Theme.VidyaPrayag.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Firebase Cloud Messaging receiver. The MESSAGING_EVENT intent-filter
          is required for FCM to route incoming pushes + token-rotation
          callbacks to VidyaPrayagFirebaseMessagingService. exported=false —
          only the Firebase system components may bind/start it; it is never
          exposed to other apps.
        -->
        <service
            android:name=".notification.VidyaPrayagFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!--
          Notification action button receiver. Handles inline actions from
          notification action buttons (e.g. Mark Read, Approve, Reject).
          exported=false — only the system notification framework may invoke it.
        -->
        <receiver
            android:name=".notification.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.littlebridge.enrollplus.notification.MARK_READ" />
            </intent-filter>
        </receiver>
    </application>

</manifest>